model UserDevice {
    id           Int       @id @default(autoincrement())
    userId       Int
    user         User      @relation(fields: [userId], references: [id])
    accessJti    String
    refreshJti   String
    ipAddress    String
    location     String
    browser      String
    os           String
    lastActivity DateTime
    status       Boolean
    createdAt    DateTime? @db.Timestamp()
    updatedAt    DateTime? @db.Timestamp()

    @@map("user_devices")
}