model Product {
    id        Int      @id @default(autoincrement())
    name     String   @db.VarChar(200)
    price   Int @default(0)
    description String @db.Text()
    createdAt DateTime @default(now()) @db.Timestamp()
    updatedAt DateTime @default(now()) @updatedAt @db.Timestamp()

    @@map("products")
}